{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "name": "git-pull-on-start",
            "type": "command",
            "command": "powershell.exe -NoProfile -File .gemini/hooks/git-pull.ps1"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "name": "git-push-on-change",
            "type": "command",
            "command": "powershell.exe -NoProfile -File .gemini/hooks/git-push.ps1"
          }
        ]
      }
    ]
  }
}
